# === Application ===
APP_NAME=ScoreForge
DEBUG=true
SECRET_KEY=your-jwt-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# === Database ===
DATABASE_URL=postgresql+asyncpg://scoreforge:password@localhost:5432/scoreforge

# === Redis ===
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# === AI Provider ===
# Options: "xiaomi" / "deepseek" / "openai"
AI_PROVIDER=xiaomi

# === Xiaomi TokenPlan ===
XIAOMI_API_KEY=
XIAOMI_API_BASE=https://token-plan-cn.xiaomimimo.com/v1
XIAOMI_GENERAL_MODEL=mimo-v2.5-pro
XIAOMI_VISION_MODEL=mimo-v2.5

# === DeepSeek ===
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_GENERAL_MODEL=deepseek-v4-flash
DEEPSEEK_VISION_MODEL=DeepSeek-VL2

# === OpenAI Compatible ===
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_GENERAL_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o

# === User API Key Encryption ===
USER_KEY_ENCRYPTION_KEY=user-key-encryption-secret

# === Alibaba Cloud OSS ===
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=scoreforge-files
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# === File Storage ===
UPLOAD_DIR=./uploads
PDF_DIR=./pdfs

# === SMS ===
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_SIGN_NAME=ScoreForge
SMS_TEMPLATE_CODE=SMS_XXX
