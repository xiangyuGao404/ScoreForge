# === Application ===
APP_NAME=ScoreForge
DEBUG=true
SECRET_KEY=your-jwt-secret-key-change-in-production
# CORS: comma-separated origins, use specific domains in production
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# === Database ===
DATABASE_URL=postgresql+asyncpg://scoreforge:password@localhost:5432/scoreforge

# === Redis ===
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# === AI Provider ===
# Options: "xiaomi" (default, Anthropic compatible) or "openai"
AI_PROVIDER=xiaomi

# === Xiaomi TokenPlan API (OpenAI Compatible) ===
XIAOMI_API_KEY=your-xiaomi-tokenplan-api-key
XIAOMI_API_BASE=https://token-plan-cn.xiaomimimo.com/v1
XIAOMI_MODEL=mimo-v2.5-pro

# === OpenAI API (backup, when AI_PROVIDER=openai) ===
OPENAI_API_KEY=sk-xxx
OPENAI_API_BASE=https://api.openai.com/v1
DEFAULT_AI_MODEL=gpt-4o

# === User API Key Encryption ===
USER_KEY_ENCRYPTION_KEY=user-key-encryption-secret

# === Alibaba Cloud OSS ===
OSS_ACCESS_KEY=LTAI5tXXX
OSS_SECRET_KEY=xxx
OSS_BUCKET=scoreforge-files
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_CDN_DOMAIN=https://files.scoreforge.app

# === File Storage ===
UPLOAD_DIR=./uploads
PDF_DIR=./pdfs

# === SMS (Alibaba Cloud) ===
SMS_ACCESS_KEY=xxx
SMS_SECRET_KEY=xxx
SMS_SIGN_NAME=ScoreForge
SMS_TEMPLATE_CODE=SMS_XXX
