# === Application ===
APP_NAME=ScoreForge
DEBUG=true
SECRET_KEY=your-jwt-secret-key-change-in-production
ALLOWED_ORIGINS=*

# === Database ===
DATABASE_URL=postgresql+asyncpg://scoreforge:password@localhost:5432/scoreforge

# === Redis ===
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# === AI API ===
OPENAI_API_KEY=sk-xxx
OPENAI_API_BASE=https://api.openai.com/v1
DEFAULT_AI_MODEL=gpt-4o

# === User API Key Encryption ===
USER_KEY_ENCRYPTION_KEY=user-key-encryption-secret

# === Alibaba Cloud OSS ===
OSS_ACCESS_KEY=LTAI5tXXX
OSS_SECRET_KEY=xxx
OSS_BUCKET=scoreforge-files
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_CDN_DOMAIN=https://files.scoreforge.app

# === File Storage ===
UPLOAD_DIR=./uploads
PDF_DIR=./pdfs

# === SMS (Alibaba Cloud) ===
SMS_ACCESS_KEY=xxx
SMS_SECRET_KEY=xxx
SMS_SIGN_NAME=ScoreForge
SMS_TEMPLATE_CODE=SMS_XXX
